{
  "name": "@snap-engine/core",
  "version": "0.4.1",
  "description": "Interactivity engine for the web",
  "type": "module",
  "workspaces": [
    "assets/asset-base/*",
    "assets/snapsort/*",
    "assets/snapline/*",
    "assets/snapzap/*"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./debug": {
      "types": "./src/debug.ts",
      "import": "./src/debug.ts"
    },
    "./animation": {
      "types": "./src/animation.ts",
      "import": "./src/animation.ts"
    },
    "./collision": {
      "types": "./src/collision.ts",
      "import": "./src/collision.ts"
    }
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev:vanilla": "FRAMEWORK=vanilla vite build --mode development --watch & npm run server:vanilla",
    "dev:react": "FRAMEWORK=react vite build --mode development --watch & npm run server:react",
    "dev:svelte": "FRAMEWORK=svelte vite build --mode development --watch & npm run server:svelte",
    "server:vanilla": "FRAMEWORK=vanilla vite serve demo/vanilla --config demo/vanilla/vite.config.mjs --host",
    "server:react": "FRAMEWORK=react vite serve demo/react --config demo/react/vite.config.mjs --host",
    "server:svelte": "FRAMEWORK=svelte vite serve demo/svelte --config demo/svelte/vite.config.mjs --host",
    "dev:all": "concurrently --kill-others \"npm run dev:vanilla\" \"npm run dev:react\"",
    "test": "start-server-and-test server:vanilla http://localhost:3001 'playwright test'",
    "test:camera-control": "playwright test -c tests/e2e/camera-control.playwright.config.ts",
    "test:camera-control-react": "playwright test -c tests/e2e/camera-control-react.playwright.config.ts",
    "test:asset-base-react": "playwright test -c tests/e2e/asset-base-react.playwright.config.ts",
    "test:snapline": "playwright test -c tests/e2e/snapline.playwright.config.ts",
    "test:snapline-camera": "playwright test -c tests/e2e/snapline-camera.playwright.config.ts",
    "test:snapline-group": "playwright test -c tests/e2e/snapline-group.playwright.config.ts",
    "test:snapline-resize": "playwright test -c tests/e2e/snapline-resize.playwright.config.ts",
    "test:snapline-react": "playwright test -c tests/e2e/snapline-react.playwright.config.ts",
    "test:layout": "playwright test -c tests/e2e/snapsort-layout.playwright.config.ts",
    "test:snapsort": "playwright test -c tests/e2e/snapsort.playwright.config.ts",
    "test:snapsort-svelte": "playwright test -c tests/e2e/snapsort.playwright.config.ts --project=svelte-chromium",
    "test:snapsort-react": "playwright test -c tests/e2e/snapsort.playwright.config.ts --project=react-chromium",
    "test:snapsort-gallery": "playwright test -c tests/e2e/snapsort-gallery.playwright.config.ts",
    "test:ui": "start-server-and-test server:vanilla http://localhost:3001 'playwright test --ui'",
    "render:collision-dots": "node scripts/render_collision_text_dots.mjs",
    "format": "prettier --write src",
    "lint": "eslint src --ext .ts",
    "build": "vite build --mode production",
    "build:dev": "FRAMEWORK=test npx vite build --mode development",
    "validate:packages": "node scripts/validate-packages.mjs",
    "check:website": "npm run check --prefix website",
    "check:adapters": "FRAMEWORK=test svelte-check --tsconfig assets/asset-base/svelte/tsconfig.json && FRAMEWORK=test svelte-check --tsconfig assets/snapsort/svelte/tsconfig.json",
    "typecheck": "tsc --noEmit",
    "ci": "npm run validate:packages && npm run typecheck && npm run lint && npm run check:adapters && npm run check:website && npm run build",
    "prepublishOnly": "npm run lint",
    "wdio": "wdio run ./wdio.conf.ts"
  },
  "keywords": [
    "ui",
    "interactive",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tfukaza/SnapEngineJS.git"
  },
  "author": "Tomoki Fukazawa",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/tfukaza/SnapEngineJS/issues"
  },
  "homepage": "https://github.com/tfukaza/SnapEngineJS#readme",
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "brace-expansion@1": "1.1.16",
    "picomatch@2": "2.3.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.6.0",
    "@playwright/test": "^1.61.1",
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@types/eslint__js": "^8.42.3",
    "@types/node": "^20.14.11",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "fontkit": "^2.0.4",
    "jsdom": "^25.0.1",
    "prettier": "3.3.2",
    "puppeteer": "^22.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sass": "^1.75.0",
    "start-server-and-test": "^2.0.4",
    "svelte-check": "^4.7.3",
    "terser": "^5.31.1",
    "tslib": "^2.6.2",
    "typescript": "^5.5.3",
    "typescript-eslint": "^7.15.0",
    "uglify-js": "^3.17.4",
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
